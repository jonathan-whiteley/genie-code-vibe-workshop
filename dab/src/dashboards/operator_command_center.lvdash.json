{
  "datasets": [
    {
      "name": "kpi_totals",
      "displayName": "KPI totals (latest 7 days)",
      "queryLines": [
        "SELECT",
        "  MEASURE(revenue) AS total_revenue,",
        "  MEASURE(labor_pct_of_sales) AS labor_pct,",
        "  MEASURE(forecast_revenue) AS total_forecast_revenue,",
        "  MEASURE(traffic) AS total_traffic",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 7 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "revenue_trend",
      "displayName": "Revenue trend, last 30 days",
      "queryLines": [
        "SELECT date AS trend_date,",
        "       MEASURE(revenue) AS revenue",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 30 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY date",
        "ORDER BY date"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "labor_pct_trend",
      "displayName": "Labor % of sales, last 30 days",
      "queryLines": [
        "SELECT date AS labor_date,",
        "       MEASURE(labor_pct_of_sales) AS labor_pct",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 30 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY date",
        "ORDER BY date"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "revenue_by_region",
      "displayName": "Revenue by region, last 30 days",
      "queryLines": [
        "SELECT region,",
        "       MEASURE(revenue) AS revenue",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 30 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY region",
        "ORDER BY revenue DESC"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "revenue_vs_forecast_by_store",
      "displayName": "Revenue vs forecast by store, current week",
      "queryLines": [
        "SELECT store_name,",
        "       MEASURE(revenue) AS revenue,",
        "       MEASURE(forecast_revenue) AS forecast_revenue",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 7 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY store_name",
        "ORDER BY revenue DESC"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "labor_vs_forecast_by_store",
      "displayName": "Labor cost vs forecast by store, current week",
      "queryLines": [
        "SELECT store_name,",
        "       MEASURE(labor_cost) AS labor_cost,",
        "       MEASURE(forecast_labor_cost) AS forecast_labor_cost",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 7 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY store_name",
        "ORDER BY labor_cost DESC"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    },
    {
      "name": "revenue_by_day_of_week",
      "displayName": "Revenue by day of week",
      "queryLines": [
        "SELECT day_of_week,",
        "       MEASURE(revenue) AS revenue",
        "FROM identifier(:catalog || '.' || :schema || '.command_center_metrics')",
        "WHERE date >= (SELECT MAX(date) - 30 FROM identifier(:catalog || '.' || :schema || '.command_center_metrics'))",
        "GROUP BY day_of_week",
        "ORDER BY revenue DESC"
      ],
      "parameters": [
        {"keyword": "catalog", "displayName": "catalog", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "ioc_sandbox"}]}}},
        {"keyword": "schema", "displayName": "schema", "dataType": "STRING", "defaultSelection": {"values": {"dataType": "STRING", "values": [{"value": "vibe_workshop"}]}}}
      ]
    }
  ],
